{
	"include": [
		"$(MODDABLE)/examples/manifest_mod.json",
		"$(MODDABLE)/examples/manifest_typings.json"
	],
	"modules": {
		"modules/*": "./modules/*",
		"*": [
			"./main",
			"./assets",
			"./layout"
		]
	},
	"platforms": {
		"*/emery": {
			"modules": {
				"modules/*": "./emery/widgets/*"
			}
		},
		"*/gabbro": {
			"modules": {
				"modules/*": "./gabbro/widgets/*"
			}
		}
	},
	"resources": {
		"*-alpha": [
			{
				"source": "./assets/IcoMoon-Regular",
				"size": 20,
				"monochrome": true,
				"blocks": [
					"Private Use Area"
				]
			}
		]
	}
}
