{
  "name": "carbon",
  "author": {
    "name": "Cory Hughart",
    "url": "https://coryhughart.com"
  },
  "version": "0.1.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "pebble": {
    "displayName": "Carbon",
    "uuid": "4a34b9c0-93b3-43ff-b1ba-a19d00cbcc60",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "emery",
      "gabbro"
    ],
    "watchapp": {
      "watchface": true
    },
    "capabilities": [
      "location"
    ],
    "messageKeys": [
      "WEATHER_REQUEST",
      "WEATHER_TEMP",
      "WEATHER_TEMP_HIGH",
      "WEATHER_TEMP_LOW",
      "WEATHER_CODE",
      "WEATHER_PRECIP_PROB",
      "WEATHER_TEMP_HOURLY",
      "WEATHER_CLOUD_COVER",
      "WEATHER_SUNRISE_HOUR",
      "WEATHER_SUNSET_HOUR",
      "CITY_NAME",
      "SETTING_TEMP_UNIT",
      "SETTING_DATE_FORMAT",
      "SETTING_ACCENT_COLOR"
    ],
    "resources": {
      "media": [
        {
          "type": "font",
          "name": "CARBON_ICONS_14",
          "file": "fonts/IcoMoon-Regular.ttf",
          "characterRegex": "[\\uE000-\\uF8FF]"
        },
        {
          "type": "font",
          "name": "CARBON_ICONS_18",
          "file": "fonts/IcoMoon-Regular.ttf",
          "characterRegex": "[\\uE000-\\uF8FF]"
        }
      ]
    }
  },
  "scripts": {
    "clean": "pebble clean",
    "gen-icons": "node scripts/gen-icons.js",
    "build": "pebble build",
    "build-run:emery": "npm run build && pebble install --emulator emery --logs",
    "build-run:gabbro": "npm run build && pebble install --emulator gabbro --logs",
    "device": "pebble install --cloudpebble",
    "fix-build": "echo '{}' > '~/Library/Application Support/Pebble SDK/settings.json'"
  },
  "dependencies": {}
}
