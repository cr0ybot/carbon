{
  "name": "carbon",
  "author": {
    "name": "Cory Hughart",
    "url": "https://coryhughart.com"
  },
  "version": "0.1.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "pebble": {
    "displayName": "Carbon",
    "uuid": "4a34b9c0-93b3-43ff-b1ba-a19d00cbcc60",
    "projectType": "moddable",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "emery",
      "gabbro"
    ],
    "watchapp": {
      "watchface": true
    },
    "messageKeys": [
      "dummy"
    ],
    "resources": {
      "media": []
    }
  },
  "scripts": {
    "clean": "rm -rf build",
    "build": "pebble build",
    "build:dev": "ALLOY_INSTRUMENTATION=1 npm run build",
    "build-run:emery": "npm run build:dev && pebble install --emulator emery --logs",
    "build-run:gabbro": "npm run build:dev && pebble install --emulator gabbro --logs",
    "device": "pebble install --cloudpebble",
    "fix-build": "echo '{}' > '~/Library/Application Support/Pebble SDK/settings.json'"
  },
  "devDependencies": {
    "@moddable/typings": "^8.0.1"
  }
}
